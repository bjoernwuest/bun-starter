{
  "name": "bun-starter",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "scripts": {
    "drizzle": "bun drizzle-kit generate --dialect postgresql --schema 'src/schema/*.ts' --out ./src/migrations --prefix timestamp && bun scripts/generate_umzug_templates.ts",
    "typegen": "bun scripts/generate_types.ts",
    "typegen:watch": "bun --watch scripts/generate_types.ts",
    "dev": "DEV_MODE=1 bun src/main.ts",
    "build": "bun build src/main.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/main.js",
    "test": "bun test"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.4",
    "@elysia/server-timing": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@monaco-editor/react": "^4.7.0",
    "@scalar/openapi-to-markdown": "^0.5.25",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28",
    "microsoft-graph-client": "^1.0.48",
    "openid-client": "^6.8.4",
    "postgres": "^3.4.9",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "umzug": "^3.8.3"
  },
  "overrides": {
    "@sinclair/typebox": "0.34"
  }
}
